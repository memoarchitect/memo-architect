{
  "name": "memo",
  "version": "0.4.4",
  "private": true,
  "description": "MEMO Architect \u2014 web workbench for medical device systems engineering (webapp of the meMO stack)",
  "scripts": {
    "build": "pnpm run check:cache && turbo build",
    "check:cache": "bash scripts/check-no-ontology-cache.sh",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "docs:serve": "pdm run docs-serve",
    "docs:build": "pdm run docs-build",
    "memo": "node memo-tools/packages/cli/lib/bin/memo.js",
    "example:dev": "cd memo-tools/memo/src/examples/gpca-pump && node ../../../../packages/cli/lib/bin/memo.js dev --port 3000",
    "setup": "pnpm install && pnpm run build && pdm install",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "~5.5.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
