<mxfile host="app.diagrams.net" version="21.0.0">
  <diagram id="memo-purpose" name="01-story-why-memo">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="pu-title" value="&lt;b&gt;01. Why MEMO Exists&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:13px;color:#4d4d4d&quot;&gt;Medical-device engineering needs a living, reviewable safety argument rather than a stack of documents that slowly drift apart.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=22;" vertex="1" parent="1"><mxGeometry x="50" y="26" width="1480" height="60" as="geometry" /></mxCell>
        <mxCell id="pu-problem" value="&lt;b&gt;The recurring problem&lt;/b&gt;" style="swimlane;fontStyle=1;align=left;startSize=38;fillColor=#f8e8e8;strokeColor=#b85450;fontSize=14;" vertex="1" parent="1"><mxGeometry x="70" y="160" width="430" height="410" as="geometry" /></mxCell>
        <mxCell id="pu-p1" value="Architecture diagrams" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=13;" vertex="1" parent="pu-problem"><mxGeometry x="38" y="72" width="354" height="48" as="geometry" /></mxCell>
        <mxCell id="pu-p2" value="Requirements and risk spreadsheets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=13;" vertex="1" parent="pu-problem"><mxGeometry x="38" y="140" width="354" height="48" as="geometry" /></mxCell>
        <mxCell id="pu-p3" value="Verification evidence and test reports" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=13;" vertex="1" parent="pu-problem"><mxGeometry x="38" y="208" width="354" height="48" as="geometry" /></mxCell>
        <mxCell id="pu-p4" value="DHF documents and audit packets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=13;" vertex="1" parent="pu-problem"><mxGeometry x="38" y="276" width="354" height="48" as="geometry" /></mxCell>
        <mxCell id="pu-drift" value="&lt;b&gt;A design change lands.&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Which evidence is still valid? Which hazards changed? Which documents must be regenerated?&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f5;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1"><mxGeometry x="610" y="282" width="380" height="116" as="geometry" /></mxCell>
        <mxCell id="pu-goal" value="&lt;b&gt;MEMO's purpose&lt;/b&gt;" style="swimlane;fontStyle=1;align=left;startSize=38;fillColor=#e6faf3;strokeColor=#0d8b6f;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1100" y="160" width="430" height="410" as="geometry" /></mxCell>
        <mxCell id="pu-g1" value="&lt;b&gt;Model the system as code&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;SysML v2 is the single engineering format.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0d8b6f;fontSize=13;" vertex="1" parent="pu-goal"><mxGeometry x="38" y="72" width="354" height="58" as="geometry" /></mxCell>
        <mxCell id="pu-g2" value="&lt;b&gt;Connect architecture to assurance&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Needs, hazards, controls, requirements, design, tests, and evidence form one graph.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0d8b6f;fontSize=13;" vertex="1" parent="pu-goal"><mxGeometry x="38" y="150" width="354" height="72" as="geometry" /></mxCell>
        <mxCell id="pu-g3" value="&lt;b&gt;Generate review-ready views&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Diagrams, compliance surfaces, and DHF artifacts remain projections of the living model.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0d8b6f;fontSize=13;" vertex="1" parent="pu-goal"><mxGeometry x="38" y="242" width="354" height="72" as="geometry" /></mxCell>
        <mxCell id="pu-out" value="&lt;b&gt;Desired outcome&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:13px&quot;&gt;When a design changes, the team can ask the model what is affected, what no longer closes, and what evidence must be refreshed.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="280" y="710" width="1040" height="86" as="geometry" /></mxCell>
        <mxCell id="pu-e1" value="drift and doubt" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#b85450;fontSize=11;" edge="1" source="pu-problem" target="pu-drift" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pu-e2" value="replace with a living model" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#0d8b6f;fontSize=11;" edge="1" source="pu-drift" target="pu-goal" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="memo-ecosystem" name="02-context-three-products">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="eco-title" value="&lt;b&gt;02. MEMO Has Three Product Parts&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:13px;color:#4d4d4d&quot;&gt;Separate portable domain content from automation and from the user experience. Each part has a clear responsibility.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=22;" vertex="1" parent="1"><mxGeometry x="50" y="26" width="1480" height="60" as="geometry" /></mxCell>
        <mxCell id="eco-user" value="&lt;b&gt;Medical-device team&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;systems engineers | safety engineers | software teams | reviewers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;" vertex="1" parent="1"><mxGeometry x="570" y="122" width="460" height="74" as="geometry" /></mxCell>
        <mxCell id="eco-architect" value="&lt;b&gt;3. memo-architect&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Guided web application&lt;br/&gt;Browser UI | viewpoint filtering | diagrams&lt;br/&gt;dashboards | artifact and compliance surfaces&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Role:&lt;/b&gt; make the model approachable and reviewable&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6faf3;strokeColor=#0d8b6f;fontSize=15;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="1050" y="290" width="440" height="270" as="geometry" /></mxCell>
        <mxCell id="eco-cli" value="&lt;b&gt;2. memo-cli&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Engineering automation engine&lt;br/&gt;Langium parser | semantic model builder&lt;br/&gt;KerML evaluator | validation | completeness&lt;br/&gt;imports | exports | dev server | WebSocket&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Role:&lt;/b&gt; turn content and project files into computable behavior&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="580" y="290" width="440" height="270" as="geometry" /></mxCell>
        <mxCell id="eco-ontology" value="&lt;b&gt;1. memo-sysmlv2&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Portable SysML v2 / KerML content&lt;br/&gt;base helpers | ontology | methodology&lt;br/&gt;viewpoints | views | rules | examples&lt;br/&gt;No TypeScript. No engine plug-ins.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Role:&lt;/b&gt; define what medical-device modeling means&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="110" y="290" width="440" height="270" as="geometry" /></mxCell>
        <mxCell id="eco-project" value="&lt;b&gt;Device project&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Project .sysml files + memo.config.yaml&lt;br/&gt;Pins a methodology. Contains concrete instances.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=14;" vertex="1" parent="1"><mxGeometry x="570" y="670" width="460" height="86" as="geometry" /></mxCell>
        <mxCell id="eco-note" value="&lt;b&gt;Dependency direction&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:13px&quot;&gt;memo-sysmlv2  &amp;lt;-  memo-cli  &amp;lt;-  memo-architect&lt;br/&gt;Domain truth flows from SysML content into tools. The UI does not own medical semantics.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;align=center;" vertex="1" parent="1"><mxGeometry x="370" y="850" width="860" height="82" as="geometry" /></mxCell>
        <mxCell id="eco-e1" value="content dependency" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#666666;fontSize=11;" edge="1" source="eco-ontology" target="eco-cli" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eco-e2" value="parsed model + validation" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#666666;fontSize=11;" edge="1" source="eco-cli" target="eco-architect" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eco-e3" value="guided review" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;strokeColor=#0d8b6f;fontSize=11;" edge="1" source="eco-user" target="eco-architect" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eco-e4" value="author + automate" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#6c8ebf;fontSize=11;" edge="1" source="eco-user" target="eco-cli" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eco-e5" value="load instances" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;strokeColor=#82b366;fontSize=11;" edge="1" source="eco-project" target="eco-cli" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eco-e6" value="pin methodology" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0;exitY=0.5;entryX=0.5;entryY=1;strokeColor=#d6b656;fontSize=11;" edge="1" source="eco-project" target="eco-ontology" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="ontology-package-map" name="03-container-ontology-packages">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="pkg-title" value="&lt;b&gt;03. Inside memo-sysmlv2: High-Level Package Composition&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:13px;color:#4d4d4d&quot;&gt;This is the container view. Start with the major packages and their responsibilities before opening the internal block diagrams.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=22;" vertex="1" parent="1"><mxGeometry x="50" y="26" width="1480" height="60" as="geometry" /></mxCell>
        <mxCell id="pkg-lib" value="&lt;b&gt;medical_device_library.sysml&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Public import wrapper: one entry point for consumers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" vertex="1" parent="1"><mxGeometry x="530" y="124" width="540" height="76" as="geometry" /></mxCell>
        <mxCell id="pkg-base" value="&lt;b&gt;base/&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;KerML stdlib wrapper&lt;br/&gt;dimensions | semantics&lt;br/&gt;methodology and rule bases&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6e6e6;strokeColor=#999999;fontSize=14;" vertex="1" parent="1"><mxGeometry x="70" y="304" width="220" height="112" as="geometry" /></mxCell>
        <mxCell id="pkg-core" value="&lt;b&gt;core/&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;common roots&lt;br/&gt;enumerations&lt;br/&gt;typed semantic links&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1"><mxGeometry x="320" y="304" width="220" height="112" as="geometry" /></mxCell>
        <mxCell id="pkg-arch" value="&lt;b&gt;architecture/&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;context | operational | system&lt;br/&gt;requirements | functions | behavior&lt;br/&gt;logical | software | hardware | physical&lt;br/&gt;risk | cyber | assurance | analysis&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef5ff;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1"><mxGeometry x="570" y="286" width="300" height="148" as="geometry" /></mxCell>
        <mxCell id="pkg-comp" value="&lt;b&gt;compliance/ + artifacts/&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;ISO 14971 RMF&lt;br/&gt;controlled artifacts&lt;br/&gt;change and post-market records&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=14;" vertex="1" parent="1"><mxGeometry x="900" y="304" width="250" height="112" as="geometry" /></mxCell>
        <mxCell id="pkg-vp" value="&lt;b&gt;viewpoints/ + views/&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;review intent&lt;br/&gt;selection queries&lt;br/&gt;diagram and document-backed views&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1180" y="304" width="250" height="112" as="geometry" /></mxCell>
        <mxCell id="pkg-rules" value="&lt;b&gt;rules/&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;closure | coverage&lt;br/&gt;cross-layer | lifecycle&lt;br/&gt;quantitative constraints&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6faf3;strokeColor=#0d8b6f;fontSize=14;" vertex="1" parent="1"><mxGeometry x="180" y="560" width="250" height="112" as="geometry" /></mxCell>
        <mxCell id="pkg-method" value="&lt;b&gt;methodology/&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;scope | workflow | gates&lt;br/&gt;patterns | profiles&lt;br/&gt;DHF bindings | GPCA tailoring&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;" vertex="1" parent="1"><mxGeometry x="500" y="560" width="250" height="112" as="geometry" /></mxCell>
        <mxCell id="pkg-man" value="&lt;b&gt;manifest/&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;release metadata&lt;br/&gt;version | changelog&lt;br/&gt;impact notes&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;" vertex="1" parent="1"><mxGeometry x="820" y="560" width="250" height="112" as="geometry" /></mxCell>
        <mxCell id="pkg-ex" value="&lt;b&gt;examples/gpca-pump/&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;reference project instances&lt;br/&gt;architecture | behavior | risk&lt;br/&gt;verification | trace | document views&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1140" y="560" width="280" height="112" as="geometry" /></mxCell>
        <mxCell id="pkg-note" value="&lt;b&gt;Reading order&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px&quot;&gt;1. base + core establish the shared language.  2. architecture + compliance + artifacts define reusable medical-device meaning.  3. viewpoints + views present that meaning.  4. rules check it.  5. methodology applies it.  6. examples prove it with instances.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="180" y="800" width="1240" height="76" as="geometry" /></mxCell>
        <mxCell id="pkg-e1" value="foundation" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.18;exitY=1;entryX=0.5;entryY=0;strokeColor=#666666;fontSize=10;" edge="1" source="pkg-lib" target="pkg-core" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pkg-e2" value="domain ontology" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#6c8ebf;fontSize=10;" edge="1" source="pkg-lib" target="pkg-arch" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pkg-e3" value="presentation" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.82;exitY=1;entryX=0.5;entryY=0;strokeColor=#9673a6;fontSize=10;" edge="1" source="pkg-lib" target="pkg-vp" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="ontology-metamodel" name="03b-high-level-metamodel">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t_ontology-metamodel" value="&lt;b&gt;03b. High-Level Metamodel — Packages, Methods, and Examples&lt;/b&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:13px;color:#4d4d4d&#x27;&gt;A more useful mental model for memo-sysmlv2: ontology packages define reusable meaning; methodology selects what a project uses.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;" vertex="1" parent="1"><mxGeometry x="50" y="24" width="1554" height="70" as="geometry"/></mxCell>
        <mxCell id="b0_ontology-metamodel" value="&lt;b&gt;Layer 0 — language helpers&lt;/b&gt;" style="swimlane;startSize=30;html=1;fontStyle=1;align=left;fillColor=#f0f0f0;strokeColor=#999999;fontSize=13;fontColor=#1f2933;swimlaneFillColor=#f0f0f0;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="50" y="120" width="1554" height="151" as="geometry"/></mxCell>
        <mxCell id="b0_ontology-metamodel_n0" value="&lt;b&gt;base/&lt;/b&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;portable helper definitions · dimensions · semantics · methodology scope helpers · rule base helpers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=12;fontColor=#1f2933;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="b0_ontology-metamodel"><mxGeometry x="18" y="40" width="748" height="97" as="geometry"/></mxCell>
        <mxCell id="b0_ontology-metamodel_n1" value="&lt;b&gt;core/&lt;/b&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;common roots · TraceableElement · enumerations · SemanticLink and typed relationship vocabulary&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=12;fontColor=#1f2933;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="b0_ontology-metamodel"><mxGeometry x="788" y="40" width="748" height="97" as="geometry"/></mxCell>
        <mxCell id="b1_ontology-metamodel" value="&lt;b&gt;Layer 1 — reusable medical-device ontology&lt;/b&gt;" style="swimlane;startSize=30;html=1;fontStyle=1;align=left;fillColor=#eef5ff;strokeColor=#6c8ebf;fontSize=13;fontColor=#1f2933;swimlaneFillColor=#eef5ff;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="50" y="311" width="1554" height="151" as="geometry"/></mxCell>
        <mxCell id="b1_ontology-metamodel_n0" value="&lt;b&gt;architecture/&lt;/b&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;the Arcadia-inspired modeling backbone: context · operational · requirements · functions · logical · software · hardware · physical · behavior · risk · assurance&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;fontColor=#1f2933;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="b1_ontology-metamodel"><mxGeometry x="18" y="40" width="491" height="97" as="geometry"/></mxCell>
        <mxCell id="b1_ontology-metamodel_n1" value="&lt;b&gt;architecture add-ons&lt;/b&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;cybersecurity · SOUP · analysis · constraints · decisions sit beside the backbone and can be selected or excluded&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;fontColor=#1f2933;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="b1_ontology-metamodel"><mxGeometry x="531" y="40" width="491" height="97" as="geometry"/></mxCell>
        <mxCell id="b1_ontology-metamodel_n2" value="&lt;b&gt;compliance/ + artifacts/&lt;/b&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;elements that model standards, controlled records, RMF/DHF content, change, and post-market evidence&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;fontColor=#1f2933;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="b1_ontology-metamodel"><mxGeometry x="1044" y="40" width="491" height="97" as="geometry"/></mxCell>
        <mxCell id="b2_ontology-metamodel" value="&lt;b&gt;Layer 2 — default presentation and standards views&lt;/b&gt;" style="swimlane;startSize=30;html=1;fontStyle=1;align=left;fillColor=#f1ebf5;strokeColor=#9673a6;fontSize=13;fontColor=#1f2933;swimlaneFillColor=#f1ebf5;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="50" y="502" width="1554" height="151" as="geometry"/></mxCell>
        <mxCell id="b2_ontology-metamodel_n0" value="&lt;b&gt;viewpoints/&lt;/b&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;default ISO 42010-style viewpoints and selection intent: risk, software architecture, cybersecurity, operational / clinical&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=12;fontColor=#1f2933;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="b2_ontology-metamodel"><mxGeometry x="18" y="40" width="491" height="97" as="geometry"/></mxCell>
        <mxCell id="b2_ontology-metamodel_n1" value="&lt;b&gt;views/&lt;/b&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;diagram and document-backed projections of the architecture and compliance graph&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=12;fontColor=#1f2933;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="b2_ontology-metamodel"><mxGeometry x="531" y="40" width="491" height="97" as="geometry"/></mxCell>
        <mxCell id="b2_ontology-metamodel_n2" value="&lt;b&gt;rules/&lt;/b&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;closure, coverage, cross-layer, lifecycle, and quantitative checks over the selected graph&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=12;fontColor=#1f2933;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="b2_ontology-metamodel"><mxGeometry x="1044" y="40" width="491" height="97" as="geometry"/></mxCell>
        <mxCell id="b3_ontology-metamodel" value="&lt;b&gt;Methodology — the project recipe&lt;/b&gt;" style="swimlane;startSize=30;html=1;fontStyle=1;align=left;fillColor=#fff6da;strokeColor=#d6b656;fontSize=13;fontColor=#1f2933;swimlaneFillColor=#fff6da;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="50" y="693" width="1554" height="151" as="geometry"/></mxCell>
        <mxCell id="b3_ontology-metamodel_n0" value="&lt;b&gt;What it is technically&lt;/b&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;SysML methodology definitions, scopes, profiles, workflows, gates, patterns, rules, and DHF bindings&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;fontColor=#1f2933;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="b3_ontology-metamodel"><mxGeometry x="18" y="40" width="491" height="97" as="geometry"/></mxCell>
        <mxCell id="b3_ontology-metamodel_n1" value="&lt;b&gt;What it chooses&lt;/b&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;which architecture layers to model · which viewpoints / views to use · which standards and artifacts to comply with&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;fontColor=#1f2933;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="b3_ontology-metamodel"><mxGeometry x="531" y="40" width="491" height="97" as="geometry"/></mxCell>
        <mxCell id="b3_ontology-metamodel_n2" value="&lt;b&gt;How teams tailor&lt;/b&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;default includes all supported scope; derived methods pick a subset with included* fields and excludedKind&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;fontColor=#1f2933;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="b3_ontology-metamodel"><mxGeometry x="1044" y="40" width="491" height="97" as="geometry"/></mxCell>
        <mxCell id="b4_ontology-metamodel" value="&lt;b&gt;Example / project — proves the tailoring&lt;/b&gt;" style="swimlane;startSize=30;html=1;fontStyle=1;align=left;fillColor=#eef7ec;strokeColor=#82b366;fontSize=13;fontColor=#1f2933;swimlaneFillColor=#eef7ec;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="50" y="884" width="1554" height="151" as="geometry"/></mxCell>
        <mxCell id="b4_ontology-metamodel_n0" value="&lt;b&gt;GPCA lightweight methodology&lt;/b&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;extends MedicalDeviceLightDefault · keeps core device layers · excludes cybersecurity concepts and SOUPComponent for a non-networked prototype&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;fontColor=#1f2933;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="b4_ontology-metamodel"><mxGeometry x="18" y="40" width="748" height="97" as="geometry"/></mxCell>
        <mxCell id="b4_ontology-metamodel_n1" value="&lt;b&gt;GPCA project model&lt;/b&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;defines concrete pump instances against that resolved method: requirements · architecture · behavior · risk · verification · trace · document views&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;fontColor=#1f2933;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="b4_ontology-metamodel"><mxGeometry x="788" y="40" width="748" height="97" as="geometry"/></mxCell>
        <mxCell id="c0_ontology-metamodel" value="gives typing and traceability to  ▼" style="endArrow=block;endFill=1;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#444444;fontSize=11;fontStyle=1;fontColor=#1f2933;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="b0_ontology-metamodel" target="b1_ontology-metamodel"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c1_ontology-metamodel" value="is projected and constrained by  ▼" style="endArrow=block;endFill=1;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#444444;fontSize=11;fontStyle=1;fontColor=#1f2933;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="b1_ontology-metamodel" target="b2_ontology-metamodel"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c2_ontology-metamodel" value="selected by  ▼" style="endArrow=block;endFill=1;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#444444;fontSize=11;fontStyle=1;fontColor=#1f2933;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="b2_ontology-metamodel" target="b3_ontology-metamodel"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c3_ontology-metamodel" value="is derived / resolved into  ▼" style="endArrow=block;endFill=1;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#444444;fontSize=11;fontStyle=1;fontColor=#1f2933;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="b3_ontology-metamodel" target="b4_ontology-metamodel"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="note_ontology-metamodel" value="&lt;b&gt;Note&lt;/b&gt;&amp;nbsp;&amp;nbsp;&lt;font style=&#x27;font-size:12px&#x27;&gt;Grounded in memo-tools/memo: base/methodology.sysml defines MethodologyScope include/exclude fields; methodology/memo includes all supported layers, standards, artifacts, and viewpoint types; methodology/gpca derives from it and subtracts cybersecurity + SOUP.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontColor=#1f2933;align=left;verticalAlign=middle;spacing=10;" vertex="1" parent="1"><mxGeometry x="50" y="1048" width="1554" height="74" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="extension-model" name="04-variation-apply-and-extend">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="ext-title" value="&lt;b&gt;04. Apply First. Extend Only When Needed.&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:13px;color:#4d4d4d&quot;&gt;Most projects select a methodology and instantiate the canonical ontology. New domain packages are an explicit, optional variation point.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=22;" vertex="1" parent="1"><mxGeometry x="50" y="26" width="1480" height="60" as="geometry" /></mxCell>
        <mxCell id="ext-core" value="&lt;b&gt;Canonical @memo/ontology&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Shared medical-device concepts&lt;br/&gt;architecture | compliance | artifacts | viewpoints&lt;br/&gt;typed relationships | invariant rules&lt;br/&gt;&lt;br/&gt;Versioned and stable for reuse.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" vertex="1" parent="1"><mxGeometry x="570" y="250" width="460" height="210" as="geometry" /></mxCell>
        <mxCell id="ext-method" value="&lt;b&gt;Tailor with methodology&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Choose included layers and standards&lt;br/&gt;hide unused kinds and documents&lt;br/&gt;adjust workflows, viewpoints, aliases, rule strengths&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Use when:&lt;/b&gt; the vocabulary already exists.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;" vertex="1" parent="1"><mxGeometry x="80" y="250" width="390" height="210" as="geometry" /></mxCell>
        <mxCell id="ext-pkg" value="&lt;b&gt;Add an extension package&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Out-of-tree @memo/ext-* package&lt;br/&gt;Namespace: memo::ontology::ext::&amp;lt;id&amp;gt;::*&lt;br/&gt;Specialize canonical kinds and add focused rules/views&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Use when:&lt;/b&gt; a real domain concept is missing.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6faf3;strokeColor=#0d8b6f;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1130" y="250" width="390" height="210" as="geometry" /></mxCell>
        <mxCell id="ext-ex1" value="&lt;b&gt;IVD extension&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;memo::ontology::ext::ivd::*&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0d8b6f;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1020" y="590" width="250" height="68" as="geometry" /></mxCell>
        <mxCell id="ext-ex2" value="&lt;b&gt;Surgical robotics extension&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;memo::ontology::ext::surgical_robotics::*&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0d8b6f;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1300" y="590" width="250" height="68" as="geometry" /></mxCell>
        <mxCell id="ext-proj" value="&lt;b&gt;Project model&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Pins ontology, methodology, and optional extension versions.&lt;br/&gt;Contains usages and project-specific exemptions, not shared type definitions.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=14;" vertex="1" parent="1"><mxGeometry x="460" y="650" width="680" height="92" as="geometry" /></mxCell>
        <mxCell id="ext-note" value="&lt;b&gt;Decision rule&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Methodology authors select and sequence. Project authors instantiate. Extension authors specialize only when the shared vocabulary truly lacks a reusable concept. This keeps the canonical ontology coherent while allowing product-family depth.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="200" y="840" width="1200" height="76" as="geometry" /></mxCell>
        <mxCell id="ext-e1" value="select subset" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d6b656;fontSize=11;" edge="1" source="ext-method" target="ext-core" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ext-e2" value="specialize and extend" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#0d8b6f;fontSize=11;" edge="1" source="ext-pkg" target="ext-core" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ext-e3" value="pin method" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.1;exitY=0;entryX=0.5;entryY=1;strokeColor=#82b366;fontSize=11;" edge="1" source="ext-proj" target="ext-method" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ext-e4" value="instantiate" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;strokeColor=#82b366;fontSize=11;" edge="1" source="ext-proj" target="ext-core" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ext-e5" value="optional package" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.9;exitY=0;entryX=0.5;entryY=1;strokeColor=#82b366;fontSize=11;" edge="1" source="ext-proj" target="ext-pkg" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="memo-guided-hierarchy" name="05-conceptual-stack">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;05. Conceptual Stack: From Shared Language to Device Evidence&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px;color:#4d4d4d&quot;&gt;Now zoom into the content model: reusable helpers, canonical ontology, methodology tailoring, and concrete project instances.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=20;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1460" height="54" as="geometry" /></mxCell>
        <mxCell id="intro" value="&lt;b&gt;Architect's mental model&lt;/b&gt;&lt;br/&gt;Think of this as an internal block diagram for the content product. The ontology is the shared vocabulary. The methodology chooses a practical subset. A project creates instances and links. Rules continuously ask whether the safety argument closes." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="40" y="84" width="1460" height="62" as="geometry" /></mxCell>

        <mxCell id="l3" value="&lt;b&gt;L3 - PROJECT MODEL&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;A specific device program instantiates the vocabulary and records its engineering argument.&lt;/font&gt;" style="swimlane;fontStyle=1;align=left;startSize=44;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;swimlaneLine=1;" vertex="1" parent="1"><mxGeometry x="40" y="170" width="1460" height="154" as="geometry" /></mxCell>
        <mxCell id="l3a" value="&lt;b&gt;Device intent&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;IntendedUse&lt;br/&gt;Actor | UseContext&lt;br/&gt;StakeholderNeed&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="l3"><mxGeometry x="32" y="62" width="220" height="70" as="geometry" /></mxCell>
        <mxCell id="l3b" value="&lt;b&gt;Device architecture&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Requirements | Functions&lt;br/&gt;SoftwareComponent&lt;br/&gt;HardwareAssembly | Interfaces&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="l3"><mxGeometry x="286" y="62" width="250" height="70" as="geometry" /></mxCell>
        <mxCell id="l3c" value="&lt;b&gt;Safety argument&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Hazard chain | Risk controls&lt;br/&gt;VerificationCase&lt;br/&gt;Evidence | Residual risk&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="l3"><mxGeometry x="570" y="62" width="250" height="70" as="geometry" /></mxCell>
        <mxCell id="l3d" value="&lt;b&gt;Controlled outputs&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;RiskManagementFile&lt;br/&gt;DHF document views&lt;br/&gt;Change and post-market records&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="l3"><mxGeometry x="854" y="62" width="250" height="70" as="geometry" /></mxCell>
        <mxCell id="l3e" value="&lt;b&gt;Example: GPCA pump&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;The final tab follows one concrete overdose-risk thread through all four boxes.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf6e8;strokeColor=#82b366;fontSize=12;" vertex="1" parent="l3"><mxGeometry x="1138" y="62" width="286" height="70" as="geometry" /></mxCell>

        <mxCell id="l2" value="&lt;b&gt;L2 - METHODOLOGY TAILORING&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;The method makes the comprehensive ontology usable for a project without forking it.&lt;/font&gt;" style="swimlane;fontStyle=1;align=left;startSize=44;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;swimlaneLine=1;" vertex="1" parent="1"><mxGeometry x="40" y="350" width="1460" height="164" as="geometry" /></mxCell>
        <mxCell id="l2a" value="&lt;b&gt;Select scope&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Architecture layers&lt;br/&gt;Standards&lt;br/&gt;Artifact kinds | Viewpoints&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="l2"><mxGeometry x="32" y="62" width="250" height="78" as="geometry" /></mxCell>
        <mxCell id="l2b" value="&lt;b&gt;Sequence work&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;WorkflowStep&lt;br/&gt;requirements -&gt; architecture&lt;br/&gt;-&gt; risk -&gt; verification&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="l2"><mxGeometry x="316" y="62" width="250" height="78" as="geometry" /></mxCell>
        <mxCell id="l2c" value="&lt;b&gt;Apply rigor&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ModelingPattern&lt;br/&gt;ElementUsageRule&lt;br/&gt;RelationUsageRule | QualityGate&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="l2"><mxGeometry x="600" y="62" width="250" height="78" as="geometry" /></mxCell>
        <mxCell id="l2d" value="&lt;b&gt;Bind deliverables&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;DHF document bindings&lt;br/&gt;Risk Management Plan&lt;br/&gt;SAD | V&amp;amp;V Plan | Threat Model&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="l2"><mxGeometry x="884" y="62" width="250" height="78" as="geometry" /></mxCell>
        <mxCell id="l2e" value="&lt;b&gt;Project binding&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ResolvedMethodology&lt;br/&gt;ProjectMethodBinding&lt;br/&gt;MethodologyBindingLink&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9e6;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="l2"><mxGeometry x="1168" y="62" width="256" height="78" as="geometry" /></mxCell>

        <mxCell id="l1" value="&lt;b&gt;L1 - CANONICAL MEDICAL-DEVICE ONTOLOGY&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Reusable SysML v2 kinds and invariant relationships cover the device lifecycle as one connected model.&lt;/font&gt;" style="swimlane;fontStyle=1;align=left;startSize=44;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;swimlaneLine=1;" vertex="1" parent="1"><mxGeometry x="40" y="540" width="1460" height="324" as="geometry" /></mxCell>
        <mxCell id="l1a" value="&lt;b&gt;1. Start with clinical intent&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;context&lt;br/&gt;IntendedUse | Actor&lt;br/&gt;UseContext | UseError&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef5ff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="l1"><mxGeometry x="30" y="66" width="206" height="94" as="geometry" /></mxCell>
        <mxCell id="l1b" value="&lt;b&gt;2. Describe operation&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;operational + system&lt;br/&gt;OperationalActivity&lt;br/&gt;Capability | Scenario&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef5ff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="l1"><mxGeometry x="266" y="66" width="206" height="94" as="geometry" /></mxCell>
        <mxCell id="l1c" value="&lt;b&gt;3. State obligations&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;requirements&lt;br/&gt;StakeholderNeed&lt;br/&gt;System | Software | Hardware Req&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="l1"><mxGeometry x="502" y="66" width="206" height="94" as="geometry" /></mxCell>
        <mxCell id="l1d" value="&lt;b&gt;4. Realize the design&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;functions + structure&lt;br/&gt;LogicalFunction | Flow&lt;br/&gt;Software | Hardware | Physical&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef5ff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="l1"><mxGeometry x="738" y="66" width="206" height="94" as="geometry" /></mxCell>
        <mxCell id="l1e" value="&lt;b&gt;5. Control risk&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;risk + cybersecurity&lt;br/&gt;Hazard | Harm | Risk&lt;br/&gt;RiskControl | Threat | Mitigation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8e8e8;strokeColor=#b85450;fontSize=12;" vertex="1" parent="l1"><mxGeometry x="974" y="66" width="206" height="94" as="geometry" /></mxCell>
        <mxCell id="l1f" value="&lt;b&gt;6. Close with evidence&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;assurance + compliance&lt;br/&gt;VerificationCase | Evidence&lt;br/&gt;RMF | Change | Post-market&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf6e8;strokeColor=#82b366;fontSize=12;" vertex="1" parent="l1"><mxGeometry x="1210" y="66" width="220" height="94" as="geometry" /></mxCell>
        <mxCell id="l1links" value="&lt;b&gt;Semantic links make the model navigable and auditable&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;RequirementSourceLink | RequirementSatisfactionLink | FunctionAllocationLink | InterfaceRealizationLink | HazardMitigationLink | VerificationLink | EvidenceProductionLink | DocumentInclusionLink | RiskTraceLink&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacing=8;" vertex="1" parent="l1"><mxGeometry x="30" y="194" width="1400" height="52" as="geometry" /></mxCell>
        <mxCell id="l1rules" value="&lt;b&gt;Invariant rule packs check closure&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Examples: each hazard has controls; each control is verified; each Class C software component has a safety class and verification; evidence is produced; required coverage exists for selected standards.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=left;spacing=8;" vertex="1" parent="l1"><mxGeometry x="30" y="258" width="1400" height="48" as="geometry" /></mxCell>

        <mxCell id="l0" value="&lt;b&gt;L0 - SYSML v2 / KerML HELPERS&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Small stable abstractions shared by ontology, methodology, rules, and models.&lt;/font&gt;" style="swimlane;fontStyle=1;align=left;startSize=44;fillColor=#e6e6e6;strokeColor=#999999;fontSize=13;swimlaneLine=1;" vertex="1" parent="1"><mxGeometry x="40" y="890" width="1460" height="160" as="geometry" /></mxCell>
        <mxCell id="l0a" value="&lt;b&gt;Identity&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;IdentifiedElement&lt;br/&gt;id | name | description&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=12;" vertex="1" parent="l0"><mxGeometry x="32" y="64" width="220" height="70" as="geometry" /></mxCell>
        <mxCell id="l0b" value="&lt;b&gt;Traceability&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;TraceableElement&lt;br/&gt;rationale | sourceReference&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=12;" vertex="1" parent="l0"><mxGeometry x="280" y="64" width="220" height="70" as="geometry" /></mxCell>
        <mxCell id="l0c" value="&lt;b&gt;Typed roots&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ArchitectureElement&lt;br/&gt;VerifiableElement | EvidenceElement&lt;br/&gt;InterfaceElement | ExchangeItem&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=12;" vertex="1" parent="l0"><mxGeometry x="528" y="64" width="260" height="70" as="geometry" /></mxCell>
        <mxCell id="l0d" value="&lt;b&gt;Portable constraints&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Native constraint def and&lt;br/&gt;require constraint bodies&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=12;" vertex="1" parent="l0"><mxGeometry x="816" y="64" width="220" height="70" as="geometry" /></mxCell>
        <mxCell id="l0e" value="&lt;b&gt;Tool portability&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Pure content layer&lt;br/&gt;SysIDE | SysON | sysand&lt;br/&gt;No engine plug-ins required&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=12;" vertex="1" parent="l0"><mxGeometry x="1064" y="64" width="360" height="70" as="geometry" /></mxCell>

        <mxCell id="up0" value="specialize and reuse" style="endArrow=block;endFill=1;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;fontSize=10;" edge="1" source="l0" target="l1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="up1" value="select and tailor" style="endArrow=block;endFill=1;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;fontSize=10;" edge="1" source="l1" target="l2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="up2" value="instantiate and govern" style="endArrow=block;endFill=1;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;fontSize=10;" edge="1" source="l2" target="l3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="flow1" value="" style="endArrow=block;endFill=1;html=1;strokeColor=#6c8ebf;" edge="1" source="l1a" target="l1b" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="flow2" value="" style="endArrow=block;endFill=1;html=1;strokeColor=#6c8ebf;" edge="1" source="l1b" target="l1c" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="flow3" value="" style="endArrow=block;endFill=1;html=1;strokeColor=#6c8ebf;" edge="1" source="l1c" target="l1d" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="flow4" value="" style="endArrow=block;endFill=1;html=1;strokeColor=#6c8ebf;" edge="1" source="l1d" target="l1e" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="flow5" value="" style="endArrow=block;endFill=1;html=1;strokeColor=#6c8ebf;" edge="1" source="l1e" target="l1f" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="core-foundations" name="06-ibd-core-foundations">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="cf-title" value="&lt;b&gt;06. IBD Zoom: Core Semantic Foundations&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px;color:#4d4d4d&quot;&gt;Most medical-device concepts specialize a deliberately small set of reusable roots from core/memo_common.sysml.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=20;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1460" height="54" as="geometry" /></mxCell>
        <mxCell id="cf-note" value="&lt;b&gt;Why start here?&lt;/b&gt;&lt;br/&gt;A stable foundation makes every later element identifiable, explainable, traceable, and queryable. Medical depth comes from specialization, not from inventing a new base type for each document." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="40" y="86" width="1460" height="60" as="geometry" /></mxCell>
        <mxCell id="cf-id" value="&lt;b&gt;IdentifiedElement&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;id : String&lt;br/&gt;name : String&lt;br/&gt;description : String&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6e6e6;strokeColor=#999999;fontSize=13;" vertex="1" parent="1"><mxGeometry x="635" y="190" width="290" height="104" as="geometry" /></mxCell>
        <mxCell id="cf-trace" value="&lt;b&gt;TraceableElement&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;rationale : String&lt;br/&gt;sourceReference : String&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1"><mxGeometry x="635" y="354" width="290" height="86" as="geometry" /></mxCell>
        <mxCell id="cf-doc" value="&lt;b&gt;DocumentedElement&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;title | shortDescription&lt;br/&gt;longDescription | documentUsage&lt;br/&gt;sectionIdentifier&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="80" y="520" width="260" height="96" as="geometry" /></mxCell>
        <mxCell id="cf-driver" value="&lt;b&gt;RequirementDriver&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Origin of an obligation&lt;br/&gt;Examples: StakeholderNeed, Risk, Threat&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1"><mxGeometry x="376" y="520" width="260" height="96" as="geometry" /></mxCell>
        <mxCell id="cf-ver" value="&lt;b&gt;VerifiableElement&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;A claim that can be checked&lt;br/&gt;Requirements | controls | properties&lt;br/&gt;verification and validation cases&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf6e8;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="672" y="520" width="260" height="96" as="geometry" /></mxCell>
        <mxCell id="cf-arch" value="&lt;b&gt;ArchitectureElement&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Part of system reasoning&lt;br/&gt;Activities | functions | components&lt;br/&gt;flows | physical nodes&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef5ff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="968" y="520" width="260" height="96" as="geometry" /></mxCell>
        <mxCell id="cf-evidence" value="&lt;b&gt;EvidenceElement&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;A record supporting a claim&lt;br/&gt;TestArtifact | Evidence&lt;br/&gt;SecurityClaim&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1264" y="520" width="260" height="96" as="geometry" /></mxCell>
        <mxCell id="cf-interface" value="&lt;b&gt;InterfaceElement&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Logical and physical boundaries&lt;br/&gt;TrustBoundary | PhysicalPort&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="376" y="690" width="260" height="82" as="geometry" /></mxCell>
        <mxCell id="cf-exchange" value="&lt;b&gt;ExchangeItem&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;semantics | unit | range&lt;br/&gt;encoding | timestampRequired&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4f1df;strokeColor=#27ae60;fontSize=12;" vertex="1" parent="1"><mxGeometry x="672" y="690" width="260" height="82" as="geometry" /></mxCell>
        <mxCell id="cf-link" value="&lt;b&gt;SemanticLink&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Typed relation with linkStatus&lt;br/&gt;Named roles at both ends&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="968" y="690" width="260" height="82" as="geometry" /></mxCell>
        <mxCell id="cf-enum" value="&lt;b&gt;Enumerations&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ConcernKind | CriticalityKind&lt;br/&gt;SafetyClassKind | HazardTypeKind&lt;br/&gt;WorkflowStageKind | AudienceKind ...&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="80" y="690" width="260" height="82" as="geometry" /></mxCell>
        <mxCell id="cf-rule" value="&lt;b&gt;Portable rule bodies&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Native KerML constraint def + require constraint expressions allow conformant tools to parse the ontology without MEMO-specific engine plug-ins.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="210" y="850" width="1160" height="66" as="geometry" /></mxCell>
        <mxCell id="cf-e1" value="specializes" style="endArrow=block;endFill=0;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="cf-trace" target="cf-id" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="cf-e2" value="" style="endArrow=block;endFill=0;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="cf-doc" target="cf-trace" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="cf-e3" value="" style="endArrow=block;endFill=0;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="cf-driver" target="cf-trace" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="cf-e4" value="" style="endArrow=block;endFill=0;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="cf-ver" target="cf-trace" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="cf-e5" value="" style="endArrow=block;endFill=0;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="cf-arch" target="cf-trace" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="cf-e6" value="" style="endArrow=block;endFill=0;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="cf-evidence" target="cf-trace" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="architecture-map" name="07-ibd-architecture-map">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="am-title" value="&lt;b&gt;07. IBD Zoom: Architecture Dimension&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px;color:#4d4d4d&quot;&gt;The canonical library imports focused architecture packages. Read left to right, then iterate as the design matures.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=20;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1480" height="54" as="geometry" /></mxCell>
        <mxCell id="am-context" value="&lt;b&gt;1. context&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;IntendedUse&lt;br/&gt;Actor | UseContext&lt;br/&gt;UseError&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d6eaf8;strokeColor=#0ea5e9;fontSize=12;" vertex="1" parent="1"><mxGeometry x="55" y="160" width="210" height="104" as="geometry" /></mxCell>
        <mxCell id="am-oper" value="&lt;b&gt;2. operational + system&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;OperationalEntity | Activity&lt;br/&gt;Capability | Scenario&lt;br/&gt;FunctionalChain | Mission&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d6eaf8;strokeColor=#0ea5e9;fontSize=12;" vertex="1" parent="1"><mxGeometry x="302" y="160" width="230" height="104" as="geometry" /></mxCell>
        <mxCell id="am-req" value="&lt;b&gt;3. requirements&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;StakeholderNeed&lt;br/&gt;SystemRequirement&lt;br/&gt;Software | Hardware Req&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1"><mxGeometry x="569" y="160" width="210" height="104" as="geometry" /></mxCell>
        <mxCell id="am-fn" value="&lt;b&gt;4. functions&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;LogicalFunction | LogicalFlow&lt;br/&gt;DataDefinition&lt;br/&gt;ControlDefinition&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdebd0;strokeColor=#e67e22;fontSize=12;" vertex="1" parent="1"><mxGeometry x="816" y="160" width="210" height="104" as="geometry" /></mxCell>
        <mxCell id="am-log" value="&lt;b&gt;5. logical design&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;LogicalComponent&lt;br/&gt;LogicalInterface&lt;br/&gt;ComponentExchange&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeafd;strokeColor=#7b68ee;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1063" y="160" width="210" height="104" as="geometry" /></mxCell>
        <mxCell id="am-real" value="&lt;b&gt;6. realization&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;SoftwareComponent | SOUP&lt;br/&gt;HardwareAssembly&lt;br/&gt;PhysicalInterface | Node | Link&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef5e4;strokeColor=#f39c12;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1310" y="160" width="230" height="104" as="geometry" /></mxCell>
        <mxCell id="am-beh" value="&lt;b&gt;behavior&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;BehaviorMachine | ModeState | Transition&lt;br/&gt;Contract | AssumeProperty | GuaranteeProperty&lt;br/&gt;InteractionScenario | TimingConstraint&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#8b5cf6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="250" y="382" width="360" height="112" as="geometry" /></mxCell>
        <mxCell id="am-risk" value="&lt;b&gt;risk + analysis&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Hazard chain | RiskBefore | RiskAfter | RiskControl&lt;br/&gt;FMEA | fault tree | HAZOP&lt;br/&gt;Risk informs requirements and design decisions&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8e8e8;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="650" y="382" width="360" height="112" as="geometry" /></mxCell>
        <mxCell id="am-cyber" value="&lt;b&gt;cybersecurity&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Asset | Threat | Vulnerability | ThreatScenario&lt;br/&gt;CyberHazard | CyberRisk | CyberMitigation&lt;br/&gt;SecurityRequirement | TrustBoundary | SecurityClaim&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eef2;strokeColor=#2c3e50;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1050" y="382" width="360" height="112" as="geometry" /></mxCell>
        <mxCell id="am-assure" value="&lt;b&gt;assurance&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;VerificationCase | ValidationCase&lt;br/&gt;TestArtifact | Evidence&lt;br/&gt;Links close claims with current evidence&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="650" y="594" width="360" height="104" as="geometry" /></mxCell>
        <mxCell id="am-dec" value="&lt;b&gt;decisions + constraints&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;DesignDecision&lt;br/&gt;MaxResponseTimeConstraint&lt;br/&gt;LockoutIntervalConstraint&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#64748b;fontSize=12;" vertex="1" parent="1"><mxGeometry x="250" y="594" width="300" height="104" as="geometry" /></mxCell>
        <mxCell id="am-out" value="&lt;b&gt;controlled views and documents&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Risk Management File | SAD | V&amp;amp;V plan&lt;br/&gt;Threat model | impact analysis&lt;br/&gt;Generated from the same linked source model&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1110" y="594" width="390" height="104" as="geometry" /></mxCell>
        <mxCell id="am-note" value="&lt;b&gt;Architect's reading&lt;/b&gt;&lt;br/&gt;Architecture is the backbone. Behavior, risk, cybersecurity, assurance, constraints, and decisions are not afterthoughts; they attach to and reshape that backbone throughout development." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6faf3;strokeColor=#0d8b6f;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="180" y="820" width="1280" height="66" as="geometry" /></mxCell>
        <mxCell id="am-e1" value="" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="am-context" target="am-oper" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="am-e2" value="" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="am-oper" target="am-req" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="am-e3" value="" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="am-req" target="am-fn" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="am-e4" value="" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="am-fn" target="am-log" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="am-e5" value="" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="am-log" target="am-real" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="am-e6" value="walk scenarios" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#8b5cf6;" edge="1" source="am-log" target="am-beh" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="am-e7" value="analyze hazards" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;" edge="1" source="am-beh" target="am-risk" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="am-e8" value="close claims" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;" edge="1" source="am-risk" target="am-assure" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="am-e9" value="compile" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;" edge="1" source="am-assure" target="am-out" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="context-requirements" name="08-ibd-context-requirements">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="cr-title" value="&lt;b&gt;08. IBD Zoom: Context and Requirements&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px;color:#4d4d4d&quot;&gt;Requirements become stronger when they remain connected to intended use, actors, scenarios, risks, and acceptance criteria.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=20;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1480" height="54" as="geometry" /></mxCell>
        <mxCell id="cr-context" value="&lt;b&gt;Context: understand use before solution&lt;/b&gt;" style="swimlane;fontStyle=1;align=left;startSize=34;fillColor=#d6eaf8;strokeColor=#0ea5e9;fontSize=13;" vertex="1" parent="1"><mxGeometry x="50" y="120" width="560" height="414" as="geometry" /></mxCell>
        <mxCell id="cr-use" value="&lt;b&gt;IntendedUse&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;indication | contraindication&lt;br/&gt;patientPopulation | clinicalBenefit&lt;br/&gt;regulatoryClassification&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0ea5e9;fontSize=12;" vertex="1" parent="cr-context"><mxGeometry x="24" y="60" width="240" height="84" as="geometry" /></mxCell>
        <mxCell id="cr-actor" value="&lt;b&gt;Actor&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;actorKind&lt;br/&gt;trainingLevel&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0ea5e9;fontSize=12;" vertex="1" parent="cr-context"><mxGeometry x="298" y="60" width="230" height="84" as="geometry" /></mxCell>
        <mxCell id="cr-ctx" value="&lt;b&gt;UseContext&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;careSetting | environment | jurisdiction&lt;br/&gt;connectedUse | intendedUseReference&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0ea5e9;fontSize=12;" vertex="1" parent="cr-context"><mxGeometry x="24" y="178" width="240" height="84" as="geometry" /></mxCell>
        <mxCell id="cr-error" value="&lt;b&gt;UseError&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;errorCategory | taskReference&lt;br/&gt;severity | rootCauseType&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0ea5e9;fontSize=12;" vertex="1" parent="cr-context"><mxGeometry x="298" y="178" width="230" height="84" as="geometry" /></mxCell>
        <mxCell id="cr-op" value="&lt;b&gt;Operational reasoning&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;OperationalEntity performs OperationalActivity&lt;br/&gt;Activities contribute to capabilities and derive system needs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef5ff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="cr-context"><mxGeometry x="24" y="302" width="504" height="76" as="geometry" /></mxCell>
        <mxCell id="cr-reqs" value="&lt;b&gt;Requirements: turn insight into explicit obligations&lt;/b&gt;" style="swimlane;fontStyle=1;align=left;startSize=34;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1"><mxGeometry x="680" y="120" width="864" height="414" as="geometry" /></mxCell>
        <mxCell id="cr-need" value="&lt;b&gt;StakeholderNeed&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;statement&lt;br/&gt;priority&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="cr-reqs"><mxGeometry x="28" y="66" width="186" height="78" as="geometry" /></mxCell>
        <mxCell id="cr-risk" value="&lt;b&gt;RiskDriver&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;risk or threat&lt;br/&gt;driverKind&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8e8e8;strokeColor=#b85450;fontSize=12;" vertex="1" parent="cr-reqs"><mxGeometry x="28" y="196" width="186" height="78" as="geometry" /></mxCell>
        <mxCell id="cr-req" value="&lt;b&gt;Requirement&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;statement | sourceKind | concernKind | status&lt;br/&gt;acceptanceCriteria | subjectDescription | actorDescription&lt;br/&gt;assumptionSummary | guaranteeSummary&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="cr-reqs"><mxGeometry x="282" y="110" width="294" height="112" as="geometry" /></mxCell>
        <mxCell id="cr-system" value="&lt;b&gt;SystemRequirement&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;system-level obligation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="cr-reqs"><mxGeometry x="638" y="64" width="196" height="62" as="geometry" /></mxCell>
        <mxCell id="cr-sw" value="&lt;b&gt;SoftwareRequirement&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;safetyClass : SafetyClassKind&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="cr-reqs"><mxGeometry x="638" y="152" width="196" height="62" as="geometry" /></mxCell>
        <mxCell id="cr-hw" value="&lt;b&gt;HardwareRequirement&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;electricalSafetyRelevant&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="cr-reqs"><mxGeometry x="638" y="240" width="196" height="62" as="geometry" /></mxCell>
        <mxCell id="cr-trace" value="&lt;b&gt;Key relationship: RequirementSourceLink&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;sourceDriver : RequirementDriver  -&gt;  targetRequirement : VerifiableElement&lt;br/&gt;sourceRole explains whether the obligation came from a need, risk, threat, regulation, or decision.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacing=8;" vertex="1" parent="1"><mxGeometry x="300" y="630" width="1040" height="76" as="geometry" /></mxCell>
        <mxCell id="cr-rule" value="&lt;b&gt;Closure expectation&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;System requirements trace to stakeholder needs. Software requirements derive from system needs or risk drivers. Every requirement carries acceptance criteria and remains linked to satisfying design elements and verification.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6faf3;strokeColor=#0d8b6f;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="190" y="790" width="1260" height="70" as="geometry" /></mxCell>
        <mxCell id="cr-e1" value="source" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;" edge="1" source="cr-need" target="cr-req" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="cr-e2" value="source" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;" edge="1" source="cr-risk" target="cr-req" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="cr-e3" value="specialize" style="endArrow=block;endFill=0;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="cr-system" target="cr-req" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="cr-e4" value="specialize" style="endArrow=block;endFill=0;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="cr-sw" target="cr-req" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="cr-e5" value="specialize" style="endArrow=block;endFill=0;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="cr-hw" target="cr-req" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="functions-behavior" name="09-ibd-functions-behavior">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="fb-title" value="&lt;b&gt;09. IBD Zoom: Functions and Behavior&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px;color:#4d4d4d&quot;&gt;Walk scenarios before formalizing: functional intent, modes, contracts, and timing constraints make architecture observable and analyzable.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=20;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1480" height="54" as="geometry" /></mxCell>
        <mxCell id="fb-fn" value="&lt;b&gt;Functional vocabulary&lt;/b&gt;" style="swimlane;fontStyle=1;align=left;startSize=34;fillColor=#fdebd0;strokeColor=#e67e22;fontSize=13;" vertex="1" parent="1"><mxGeometry x="50" y="120" width="460" height="444" as="geometry" /></mxCell>
        <mxCell id="fb-lf" value="&lt;b&gt;LogicalFunction&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;functionCategory | trigger | outputSummary&lt;br/&gt;concernKind | criticality&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e67e22;fontSize=12;" vertex="1" parent="fb-fn"><mxGeometry x="24" y="62" width="412" height="76" as="geometry" /></mxCell>
        <mxCell id="fb-flow" value="&lt;b&gt;LogicalFlow&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;flowKind | direction | latencyBudgetMs&lt;br/&gt;staleAfterMs | integrityLevel&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e67e22;fontSize=12;" vertex="1" parent="fb-fn"><mxGeometry x="24" y="160" width="412" height="76" as="geometry" /></mxCell>
        <mxCell id="fb-data" value="&lt;b&gt;DataDefinition&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ExchangeItem + confidentiality, integrity, availability classes&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e67e22;fontSize=12;" vertex="1" parent="fb-fn"><mxGeometry x="24" y="258" width="412" height="62" as="geometry" /></mxCell>
        <mxCell id="fb-control" value="&lt;b&gt;ControlDefinition&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ExchangeItem + controlType | timeoutMs | retryPolicy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e67e22;fontSize=12;" vertex="1" parent="fb-fn"><mxGeometry x="24" y="342" width="412" height="62" as="geometry" /></mxCell>
        <mxCell id="fb-beh" value="&lt;b&gt;Behavior vocabulary&lt;/b&gt;" style="swimlane;fontStyle=1;align=left;startSize=34;fillColor=#ede9fe;strokeColor=#8b5cf6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="560" y="120" width="984" height="444" as="geometry" /></mxCell>
        <mxCell id="fb-machine" value="&lt;b&gt;BehaviorMachine&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;machineKind&lt;br/&gt;executionSemantics&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8b5cf6;fontSize=12;" vertex="1" parent="fb-beh"><mxGeometry x="28" y="64" width="206" height="74" as="geometry" /></mxCell>
        <mxCell id="fb-state" value="&lt;b&gt;ModeState&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;modeKind&lt;br/&gt;entryCondition | exitCondition&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8b5cf6;fontSize=12;" vertex="1" parent="fb-beh"><mxGeometry x="266" y="64" width="206" height="74" as="geometry" /></mxCell>
        <mxCell id="fb-trans" value="&lt;b&gt;Transition&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;trigger | guard | effect | priority&lt;br/&gt;sameStepCritical | sourceState | targetState&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8b5cf6;fontSize=12;" vertex="1" parent="fb-beh"><mxGeometry x="504" y="64" width="230" height="74" as="geometry" /></mxCell>
        <mxCell id="fb-scenario" value="&lt;b&gt;InteractionScenario + Message&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;scenarioKind | sender | receiver&lt;br/&gt;exchangeItem | sequenceOrder | timing&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8b5cf6;fontSize=12;" vertex="1" parent="fb-beh"><mxGeometry x="766" y="64" width="190" height="74" as="geometry" /></mxCell>
        <mxCell id="fb-contract" value="&lt;b&gt;Contract&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;contractScope&lt;br/&gt;links claims to architecture&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8b5cf6;fontSize=12;" vertex="1" parent="fb-beh"><mxGeometry x="150" y="214" width="206" height="74" as="geometry" /></mxCell>
        <mxCell id="fb-prop" value="&lt;b&gt;BehaviorProperty&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;propertyKind | languageKind&lt;br/&gt;formalExpression&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8b5cf6;fontSize=12;" vertex="1" parent="fb-beh"><mxGeometry x="390" y="214" width="206" height="74" as="geometry" /></mxCell>
        <mxCell id="fb-assume" value="&lt;b&gt;AssumeProperty&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;what must be true&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef5ff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="fb-beh"><mxGeometry x="646" y="194" width="188" height="60" as="geometry" /></mxCell>
        <mxCell id="fb-guar" value="&lt;b&gt;GuaranteeProperty&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;what design promises&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf6e8;strokeColor=#82b366;fontSize=12;" vertex="1" parent="fb-beh"><mxGeometry x="646" y="276" width="188" height="60" as="geometry" /></mxCell>
        <mxCell id="fb-time" value="&lt;b&gt;TimingConstraint&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;minMs | maxMs | referenceElement&lt;br/&gt;verificationMethod&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#64748b;fontSize=12;" vertex="1" parent="fb-beh"><mxGeometry x="150" y="330" width="444" height="66" as="geometry" /></mxCell>
        <mxCell id="fb-note" value="&lt;b&gt;Practical sequence&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Start with scenarios and messages. Identify modes and transitions. Add timing constraints. Formalize the highest-risk promises as assume/guarantee properties. Link those verifiable properties to model checking or tests.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6faf3;strokeColor=#0d8b6f;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="170" y="690" width="1300" height="76" as="geometry" /></mxCell>
        <mxCell id="fb-e1" value="contains" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#8b5cf6;" edge="1" source="fb-machine" target="fb-state" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fb-e2" value="connects" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#8b5cf6;" edge="1" source="fb-state" target="fb-trans" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fb-e3" value="observed as" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#8b5cf6;" edge="1" source="fb-scenario" target="fb-trans" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fb-e4" value="scopes" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#8b5cf6;" edge="1" source="fb-contract" target="fb-prop" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fb-e5" value="" style="endArrow=block;endFill=0;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="fb-assume" target="fb-prop" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fb-e6" value="" style="endArrow=block;endFill=0;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="fb-guar" target="fb-prop" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="design-realization" name="10-ibd-design-realization">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="dr-title" value="&lt;b&gt;10. IBD Zoom: Logical, Software, Hardware, and Physical Realization&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px;color:#4d4d4d&quot;&gt;Keep responsibilities, exchanges, deployment, timing, and interfaces explicit as the solution becomes concrete.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=20;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1480" height="54" as="geometry" /></mxCell>
        <mxCell id="dr-log" value="&lt;b&gt;Logical design&lt;/b&gt;" style="swimlane;fontStyle=1;align=left;startSize=34;fillColor=#eeeafd;strokeColor=#7b68ee;fontSize=13;" vertex="1" parent="1"><mxGeometry x="48" y="130" width="340" height="388" as="geometry" /></mxCell>
        <mxCell id="dr-comp" value="&lt;b&gt;LogicalComponent&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;responsibility&lt;br/&gt;decompositionLevel&lt;br/&gt;safetyPartition&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7b68ee;fontSize=12;" vertex="1" parent="dr-log"><mxGeometry x="24" y="62" width="292" height="82" as="geometry" /></mxCell>
        <mxCell id="dr-li" value="&lt;b&gt;LogicalInterface&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;domainKind | interfaceKind | direction&lt;br/&gt;interactionPattern | protocolSemantics&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7b68ee;fontSize=12;" vertex="1" parent="dr-log"><mxGeometry x="24" y="176" width="292" height="82" as="geometry" /></mxCell>
        <mxCell id="dr-ex" value="&lt;b&gt;ComponentExchange&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;sourcePort | targetPort&lt;br/&gt;allocatedFunctionalExchanges | direction&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7b68ee;fontSize=12;" vertex="1" parent="dr-log"><mxGeometry x="24" y="290" width="292" height="68" as="geometry" /></mxCell>
        <mxCell id="dr-sw" value="&lt;b&gt;Software realization&lt;/b&gt;" style="swimlane;fontStyle=1;align=left;startSize=34;fillColor=#fef5e4;strokeColor=#f39c12;fontSize=13;" vertex="1" parent="1"><mxGeometry x="424" y="130" width="340" height="388" as="geometry" /></mxCell>
        <mxCell id="dr-sys" value="&lt;b&gt;SoftwareSystem&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;version | lifecycleState&lt;br/&gt;safetyClass | complexity | OS&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f39c12;fontSize=12;" vertex="1" parent="dr-sw"><mxGeometry x="24" y="62" width="292" height="72" as="geometry" /></mxCell>
        <mxCell id="dr-swc" value="&lt;b&gt;SoftwareComponent&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;responsibility | safetyClass | complexity&lt;br/&gt;periodMs | deadlineMs | wcetMs&lt;br/&gt;schedulingPolicy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f39c12;fontSize=12;" vertex="1" parent="dr-sw"><mxGeometry x="24" y="158" width="292" height="88" as="geometry" /></mxCell>
        <mxCell id="dr-soup" value="&lt;b&gt;SOUPComponent + SBOMEntry&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;vendor | version | known anomalies&lt;br/&gt;risk acceptance | license | hash&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f39c12;fontSize=12;" vertex="1" parent="dr-sw"><mxGeometry x="24" y="278" width="292" height="80" as="geometry" /></mxCell>
        <mxCell id="dr-hw" value="&lt;b&gt;Hardware realization&lt;/b&gt;" style="swimlane;fontStyle=1;align=left;startSize=34;fillColor=#f5f5f5;strokeColor=#95a5a6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="800" y="130" width="340" height="388" as="geometry" /></mxCell>
        <mxCell id="dr-hwa" value="&lt;b&gt;HardwareAssembly&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;responsibility | safetyRole | partNumber&lt;br/&gt;MTBF | protectionClass | ipRating&lt;br/&gt;lifecycleState&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#95a5a6;fontSize=12;" vertex="1" parent="dr-hw"><mxGeometry x="24" y="62" width="292" height="92" as="geometry" /></mxCell>
        <mxCell id="dr-hwi" value="&lt;b&gt;HardwareInterface&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;PhysicalInterface + electricalStandard&lt;br/&gt;nominalVoltageV | nominalCurrentA&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#95a5a6;fontSize=12;" vertex="1" parent="dr-hw"><mxGeometry x="24" y="198" width="292" height="78" as="geometry" /></mxCell>
        <mxCell id="dr-life" value="&lt;b&gt;Lifecycle state matters&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;design, development, released, retired&lt;br/&gt;are model attributes used by rules and views&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#95a5a6;fontSize=12;" vertex="1" parent="dr-hw"><mxGeometry x="24" y="304" width="292" height="54" as="geometry" /></mxCell>
        <mxCell id="dr-phy" value="&lt;b&gt;Physical deployment&lt;/b&gt;" style="swimlane;fontStyle=1;align=left;startSize=34;fillColor=#e8eef2;strokeColor=#64748b;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1176" y="130" width="340" height="388" as="geometry" /></mxCell>
        <mxCell id="dr-node" value="&lt;b&gt;ProcessingNode&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;nodeKind | processorArchitecture | memory&lt;br/&gt;OS | safetyPartition | redundancy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;fontSize=12;" vertex="1" parent="dr-phy"><mxGeometry x="24" y="62" width="292" height="82" as="geometry" /></mxCell>
        <mxCell id="dr-pl" value="&lt;b&gt;PhysicalLink&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;linkKind | bandwidth | latency&lt;br/&gt;reliability | safetyRelevant&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;fontSize=12;" vertex="1" parent="dr-phy"><mxGeometry x="24" y="176" width="292" height="72" as="geometry" /></mxCell>
        <mxCell id="dr-port" value="&lt;b&gt;PhysicalPort&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;portKind | connectorType | direction&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;fontSize=12;" vertex="1" parent="dr-phy"><mxGeometry x="24" y="280" width="292" height="64" as="geometry" /></mxCell>
        <mxCell id="dr-links" value="&lt;b&gt;Allocation and realization links&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;FunctionAllocationLink allocates function to architecture. InterfaceRealizationLink connects logical and physical interfaces. DeploysOnto maps software components to hardware assemblies. HostedBy maps processing nodes to assemblies. RealizesComponentExchange ties physical links back to component exchanges.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="140" y="650" width="1360" height="82" as="geometry" /></mxCell>
        <mxCell id="dr-note" value="&lt;b&gt;Architect's question&lt;/b&gt;&lt;br/&gt;Can we navigate from a safety-relevant function to its software component, timing budget, host assembly, physical interfaces, and verification evidence without switching truth sources?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6faf3;strokeColor=#0d8b6f;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="270" y="820" width="1100" height="68" as="geometry" /></mxCell>
        <mxCell id="dr-e1" value="allocate responsibility" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7b68ee;fontSize=10;" edge="1" source="dr-comp" target="dr-swc" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="dr-e2" value="InterfaceRealizationLink" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;fontSize=10;" edge="1" source="dr-li" target="dr-hwi" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="dr-e3" value="DeploysOnto" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#f39c12;fontSize=10;" edge="1" source="dr-swc" target="dr-node" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="dr-e4" value="HostedBy" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#64748b;fontSize=10;" edge="1" source="dr-node" target="dr-hwa" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="dr-e5" value="realizes exchange" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#64748b;fontSize=10;" edge="1" source="dr-ex" target="dr-pl" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="risk-cyber" name="11-ibd-risk-cybersecurity">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="rc-title" value="&lt;b&gt;11. IBD Zoom: Risk and Cybersecurity&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px;color:#4d4d4d&quot;&gt;Safety hazards and security threats are peer analysis layers with parallel downstream machinery: drivers, requirements, controls, verification, evidence.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=20;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1480" height="54" as="geometry" /></mxCell>
        <mxCell id="rc-risk" value="&lt;b&gt;Safety risk chain - ISO 14971 style&lt;/b&gt;" style="swimlane;fontStyle=1;align=left;startSize=34;fillColor=#f8e8e8;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1"><mxGeometry x="50" y="130" width="1490" height="214" as="geometry" /></mxCell>
        <mxCell id="rc-haz" value="&lt;b&gt;Hazard&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;hazardType | severity&lt;br/&gt;foreseeable&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=12;" vertex="1" parent="rc-risk"><mxGeometry x="24" y="76" width="170" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-seq" value="&lt;b&gt;SequenceOfEvents&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;initiatingEvent&lt;br/&gt;contributingFactors&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=12;" vertex="1" parent="rc-risk"><mxGeometry x="224" y="76" width="180" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-sit" value="&lt;b&gt;HazardousSituation&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;exposedPersons&lt;br/&gt;operatingCondition&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=12;" vertex="1" parent="rc-risk"><mxGeometry x="434" y="76" width="180" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-harm" value="&lt;b&gt;Harm&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;clinicalImpact&lt;br/&gt;reversibility | criticality&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=12;" vertex="1" parent="rc-risk"><mxGeometry x="644" y="76" width="180" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-before" value="&lt;b&gt;RiskBeforeMitigation&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;probability | severity | level&lt;br/&gt;acceptability | misuse included&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=12;" vertex="1" parent="rc-risk"><mxGeometry x="854" y="76" width="196" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-control" value="&lt;b&gt;RiskControl&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;controlKind&lt;br/&gt;implementationKind&lt;br/&gt;verificationStatus&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="rc-risk"><mxGeometry x="1080" y="76" width="174" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-after" value="&lt;b&gt;RiskAfterMitigation&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;residual probability | severity&lt;br/&gt;acceptability | benefit-risk required&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf6e8;strokeColor=#82b366;fontSize=12;" vertex="1" parent="rc-risk"><mxGeometry x="1284" y="76" width="182" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-cyber" value="&lt;b&gt;Cybersecurity chain - threat analysis with safety linkage&lt;/b&gt;" style="swimlane;fontStyle=1;align=left;startSize=34;fillColor=#e8eef2;strokeColor=#2c3e50;fontSize=13;" vertex="1" parent="1"><mxGeometry x="50" y="400" width="1490" height="214" as="geometry" /></mxCell>
        <mxCell id="rc-asset" value="&lt;b&gt;CybersecurityAsset&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;CIA needs | privacyRelevant&lt;br/&gt;safetyRelevant | owner&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2c3e50;fontSize=12;" vertex="1" parent="rc-cyber"><mxGeometry x="24" y="76" width="190" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-threat" value="&lt;b&gt;Threat&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;RequirementDriver&lt;br/&gt;STRIDE category | vector&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2c3e50;fontSize=12;" vertex="1" parent="rc-cyber"><mxGeometry x="244" y="76" width="174" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-vuln" value="&lt;b&gt;Vulnerability&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;weakness | exploitability&lt;br/&gt;CWE ref | remediable&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2c3e50;fontSize=12;" vertex="1" parent="rc-cyber"><mxGeometry x="448" y="76" width="174" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-ts" value="&lt;b&gt;ThreatScenario&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;actor | assumptions&lt;br/&gt;security objective | abuse case&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2c3e50;fontSize=12;" vertex="1" parent="rc-cyber"><mxGeometry x="652" y="76" width="174" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-ch" value="&lt;b&gt;CyberHazard + CyberRisk&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;safety and privacy impact&lt;br/&gt;exploitability | complexity&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8e8e8;strokeColor=#b85450;fontSize=12;" vertex="1" parent="rc-cyber"><mxGeometry x="856" y="76" width="196" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-mit" value="&lt;b&gt;CyberMitigation&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Cyber control kind&lt;br/&gt;mechanism | verification&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="rc-cyber"><mxGeometry x="1082" y="76" width="174" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-sreq" value="&lt;b&gt;SecurityRequirement + Claim&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;derived from threat and risk&lt;br/&gt;supported by evidence&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf6e8;strokeColor=#82b366;fontSize=12;" vertex="1" parent="rc-cyber"><mxGeometry x="1286" y="76" width="180" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-links" value="&lt;b&gt;Typed links preserve the reasoning&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;RiskTraceLink records roles such as initiates, leadsTo, canCause, assessedAgainst, resultsIn, aggregates. Cyber links connect assets, threats, vulnerabilities, scenarios, mitigations, trust-boundary crossings, security requirements, and safety hazards.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="160" y="700" width="1320" height="76" as="geometry" /></mxCell>
        <mxCell id="rc-note" value="&lt;b&gt;Why peers?&lt;/b&gt;&lt;br/&gt;Threat specializes RequirementDriver, just like Risk. Both produce obligations and controls that must be verified. CyberSafetyTraceLink makes security-to-safety interactions explicit." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6faf3;strokeColor=#0d8b6f;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="240" y="850" width="1160" height="68" as="geometry" /></mxCell>
        <mxCell id="rc-e1" value="" style="endArrow=block;html=1;strokeColor=#b85450;" edge="1" source="rc-haz" target="rc-seq" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="rc-e2" value="" style="endArrow=block;html=1;strokeColor=#b85450;" edge="1" source="rc-seq" target="rc-sit" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="rc-e3" value="" style="endArrow=block;html=1;strokeColor=#b85450;" edge="1" source="rc-sit" target="rc-harm" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="rc-e4" value="" style="endArrow=block;html=1;strokeColor=#b85450;" edge="1" source="rc-harm" target="rc-before" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="rc-e5" value="" style="endArrow=block;html=1;strokeColor=#b85450;" edge="1" source="rc-before" target="rc-control" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="rc-e6" value="" style="endArrow=block;html=1;strokeColor=#b85450;" edge="1" source="rc-control" target="rc-after" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rc-e7" value="" style="endArrow=block;html=1;strokeColor=#2c3e50;" edge="1" source="rc-asset" target="rc-threat" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="rc-e8" value="" style="endArrow=block;html=1;strokeColor=#2c3e50;" edge="1" source="rc-threat" target="rc-vuln" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="rc-e9" value="" style="endArrow=block;html=1;strokeColor=#2c3e50;" edge="1" source="rc-vuln" target="rc-ts" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="rc-e10" value="" style="endArrow=block;html=1;strokeColor=#2c3e50;" edge="1" source="rc-ts" target="rc-ch" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="rc-e11" value="" style="endArrow=block;html=1;strokeColor=#2c3e50;" edge="1" source="rc-ch" target="rc-mit" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="rc-e12" value="" style="endArrow=block;html=1;strokeColor=#2c3e50;" edge="1" source="rc-mit" target="rc-sreq" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="assurance-closure" name="12-ibd-assurance-closure">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="ac-title" value="&lt;b&gt;12. IBD Zoom: Assurance Closure&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px;color:#4d4d4d&quot;&gt;The objective is a checkable path from claim to current evidence, not a large collection of disconnected files.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=20;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1480" height="54" as="geometry" /></mxCell>
        <mxCell id="ac-claim" value="&lt;b&gt;Verifiable target&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Requirement&lt;br/&gt;RiskControl&lt;br/&gt;BehaviorProperty&lt;br/&gt;Architecture element&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1"><mxGeometry x="90" y="250" width="230" height="118" as="geometry" /></mxCell>
        <mxCell id="ac-vcase" value="&lt;b&gt;VerificationCase&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;methodKind&lt;br/&gt;acceptanceCriteria&lt;br/&gt;status&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf6e8;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="410" y="250" width="230" height="118" as="geometry" /></mxCell>
        <mxCell id="ac-test" value="&lt;b&gt;TestArtifact&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;version&lt;br/&gt;lifecycleState&lt;br/&gt;artifactKind&lt;br/&gt;resultSummary&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="730" y="180" width="230" height="118" as="geometry" /></mxCell>
        <mxCell id="ac-evidence" value="&lt;b&gt;Evidence&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;version&lt;br/&gt;lifecycleState&lt;br/&gt;evidenceType&lt;br/&gt;integrityStatus&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="730" y="342" width="230" height="118" as="geometry" /></mxCell>
        <mxCell id="ac-view" value="&lt;b&gt;DocumentBackedView&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;version | lifecycleState&lt;br/&gt;generationRule | marketScope&lt;br/&gt;Examples: RMF, SAD, V&amp;amp;V view&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1050" y="250" width="250" height="118" as="geometry" /></mxCell>
        <mxCell id="ac-rmf" value="&lt;b&gt;RiskManagementFile&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ISO 14971 top-level deliverable&lt;br/&gt;standard | clause | edition&lt;br/&gt;completenessStatus&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1390" y="250" width="220" height="118" as="geometry" /></mxCell>
        <mxCell id="ac-val" value="&lt;b&gt;ValidationCase&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;validationMethod | userParticipation&lt;br/&gt;acceptanceCriteria | clinicalContext&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef5ff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="410" y="470" width="230" height="84" as="geometry" /></mxCell>
        <mxCell id="ac-links" value="&lt;b&gt;Typed assurance relationships&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;VerificationLink connects a target to a verification case. Validates connects a target to a validation case. EvidenceProductionLink connects a case to an evidence record. DocumentInclusionLink includes evidence and related model content in a controlled view.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="180" y="650" width="1280" height="76" as="geometry" /></mxCell>
        <mxCell id="ac-rule" value="&lt;b&gt;Closure rules ask direct questions&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Does every risk control have verification? Does each Class C software component have rigorous verification? Does every verification case state a method and target? Does it produce evidence? Can document views compile the current evidence set?&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6faf3;strokeColor=#0d8b6f;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="180" y="800" width="1280" height="76" as="geometry" /></mxCell>
        <mxCell id="ac-e1" value="VerificationLink" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;" edge="1" source="ac-claim" target="ac-vcase" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ac-e2" value="produces" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;" edge="1" source="ac-vcase" target="ac-test" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ac-e3" value="EvidenceProductionLink" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;" edge="1" source="ac-vcase" target="ac-evidence" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ac-e4" value="DocumentInclusionLink" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;" edge="1" source="ac-evidence" target="ac-view" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ac-e5" value="aggregates" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;" edge="1" source="ac-view" target="ac-rmf" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ac-e6" value="Validates" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;" edge="1" source="ac-claim" target="ac-val" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="links-rules" name="13-semantic-links-and-rules">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="lr-title" value="&lt;b&gt;13. Semantic Links and Rules: Make the Graph Computable&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px;color:#4d4d4d&quot;&gt;Links carry named roles and status. Native rules check closure and quantitative expectations over that graph.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=20;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1480" height="54" as="geometry" /></mxCell>
        <mxCell id="lr-base" value="&lt;b&gt;SemanticLink&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;specializes TraceableElement&lt;br/&gt;linkStatus : LinkStatusKind&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="650" y="126" width="290" height="82" as="geometry" /></mxCell>
        <mxCell id="lr-req" value="&lt;b&gt;Requirement links&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;RequirementSourceLink&lt;br/&gt;RequirementSatisfactionLink&lt;br/&gt;DerivesInto&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1"><mxGeometry x="70" y="280" width="250" height="96" as="geometry" /></mxCell>
        <mxCell id="lr-arch" value="&lt;b&gt;Architecture links&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;FunctionAllocationLink&lt;br/&gt;InterfaceRealizationLink&lt;br/&gt;Composes | AllocatesExchange | DeploysOnto&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef5ff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="370" y="280" width="250" height="96" as="geometry" /></mxCell>
        <mxCell id="lr-risk" value="&lt;b&gt;Risk + cyber links&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;HazardMitigationLink | RiskTraceLink&lt;br/&gt;AssetThreatLink | ThreatVulnerabilityLink&lt;br/&gt;CyberSafetyTraceLink | TrustBoundaryCrossing&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8e8e8;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="670" y="280" width="270" height="96" as="geometry" /></mxCell>
        <mxCell id="lr-assure" value="&lt;b&gt;Assurance links&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;VerificationLink | Validates&lt;br/&gt;EvidenceProductionLink&lt;br/&gt;DocumentInclusionLink&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf6e8;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="990" y="280" width="250" height="96" as="geometry" /></mxCell>
        <mxCell id="lr-other" value="&lt;b&gt;Lifecycle + analysis links&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ExecutionOrderLink | MethodologyBindingLink&lt;br/&gt;HasFailureMode | CausesEffect | DetectedBy&lt;br/&gt;Changes | FeedsBackTo | Decides&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#64748b;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1290" y="280" width="270" height="96" as="geometry" /></mxCell>
        <mxCell id="lr-closure" value="&lt;b&gt;Closure rules&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;hazard has mitigation&lt;br/&gt;risk control has verification&lt;br/&gt;software requirement has trace&lt;br/&gt;Class C component has verification&lt;br/&gt;verification case produces evidence&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6faf3;strokeColor=#0d8b6f;fontSize=12;" vertex="1" parent="1"><mxGeometry x="90" y="510" width="310" height="136" as="geometry" /></mxCell>
        <mxCell id="lr-cover" value="&lt;b&gt;Coverage rules&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ISO 14971: hazards, matrix, residual risk&lt;br/&gt;IEC 62304: software architecture + requirements&lt;br/&gt;21 CFR 820: design input + verification&lt;br/&gt;IEC 62366: actors | FDA cyber: assets, threats, controls&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="450" y="510" width="340" height="136" as="geometry" /></mxCell>
        <mxCell id="lr-cross" value="&lt;b&gt;Cross-layer rules&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Check that obligations connect across layers:&lt;br/&gt;need/risk -&gt; requirement -&gt; architecture&lt;br/&gt;-&gt; verification -&gt; evidence -&gt; document view&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="840" y="510" width="310" height="136" as="geometry" /></mxCell>
        <mxCell id="lr-quant" value="&lt;b&gt;Quantitative + lifecycle rules&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;timing | resource | risk thresholds&lt;br/&gt;lifecycle state | baseline expectations&lt;br/&gt;model-level completeness tooling&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#64748b;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1200" y="510" width="310" height="136" as="geometry" /></mxCell>
        <mxCell id="lr-note" value="&lt;b&gt;Important distinction&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Per-subject KerML constraints evaluate local graph closure. Model-level coverage asks whether the project contains expected kinds for its selected standards. Together they turn an ontology into a continuously reviewable engineering argument.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6faf3;strokeColor=#0d8b6f;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="190" y="780" width="1260" height="76" as="geometry" /></mxCell>
        <mxCell id="lr-e1" value="" style="endArrow=block;endFill=0;html=1;strokeColor=#9673a6;" edge="1" source="lr-req" target="lr-base" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="lr-e2" value="" style="endArrow=block;endFill=0;html=1;strokeColor=#9673a6;" edge="1" source="lr-arch" target="lr-base" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="lr-e3" value="" style="endArrow=block;endFill=0;html=1;strokeColor=#9673a6;" edge="1" source="lr-risk" target="lr-base" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="lr-e4" value="" style="endArrow=block;endFill=0;html=1;strokeColor=#9673a6;" edge="1" source="lr-assure" target="lr-base" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="lr-e5" value="" style="endArrow=block;endFill=0;html=1;strokeColor=#9673a6;" edge="1" source="lr-other" target="lr-base" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="viewpoints-documents" name="14-viewpoints-and-documents">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="vd-title" value="&lt;b&gt;14. Viewpoints, Views, and Documents: Present the Same Truth Differently&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px;color:#4d4d4d&quot;&gt;A viewpoint declares intent. A view binds that intent to selected model content. Documents become controlled views, not parallel truth sources.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=20;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1480" height="54" as="geometry" /></mxCell>
        <mxCell id="vd-vp" value="&lt;b&gt;Viewpoint&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;purpose | audience | stage | abstractionLevel&lt;br/&gt;outputKind | presentationKind | concern&lt;br/&gt;includedLayers | allowed kinds | filter expression&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d6eaf8;strokeColor=#0ea5e9;fontSize=13;" vertex="1" parent="1"><mxGeometry x="80" y="200" width="330" height="120" as="geometry" /></mxCell>
        <mxCell id="vd-query" value="&lt;b&gt;ViewSelectionQuery&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;include element kinds | relationships | layers&lt;br/&gt;concerns | status tags | selection expression&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="520" y="200" width="330" height="120" as="geometry" /></mxCell>
        <mxCell id="vd-view" value="&lt;b&gt;View&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;bound viewpoint | subject&lt;br/&gt;exposesElement | exposesRelationship&lt;br/&gt;selectionQuery | autoPopulate&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef5ff;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1"><mxGeometry x="960" y="200" width="300" height="120" as="geometry" /></mxCell>
        <mxCell id="vd-out" value="&lt;b&gt;Presentations&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;DiagramView&lt;br/&gt;DocumentBackedView&lt;br/&gt;table | matrix | custom rendering&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1360" y="200" width="220" height="120" as="geometry" /></mxCell>
        <mxCell id="vd-context" value="&lt;b&gt;VP-CTX Context&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;actors, use context, boundaries&lt;br/&gt;audience: system architect&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d6eaf8;strokeColor=#0ea5e9;fontSize=12;" vertex="1" parent="1"><mxGeometry x="110" y="470" width="250" height="82" as="geometry" /></mxCell>
        <mxCell id="vd-log" value="&lt;b&gt;VP-LOG Logical Architecture&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;functions, logical structure, interfaces&lt;br/&gt;audience: system architect&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeafd;strokeColor=#7b68ee;fontSize=12;" vertex="1" parent="1"><mxGeometry x="410" y="470" width="250" height="82" as="geometry" /></mxCell>
        <mxCell id="vd-risk" value="&lt;b&gt;VP-RISK Risk and Control&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;hazard, situation, harm, control, verification&lt;br/&gt;audience: safety engineer&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8e8e8;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="710" y="470" width="250" height="82" as="geometry" /></mxCell>
        <mxCell id="vd-cyb" value="&lt;b&gt;VP-CYB Cybersecurity&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;assets, threats, vulnerabilities, trust boundaries&lt;br/&gt;audience: security engineer&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eef2;strokeColor=#2c3e50;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1010" y="470" width="250" height="82" as="geometry" /></mxCell>
        <mxCell id="vd-docs" value="&lt;b&gt;DHF / compliance outputs&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Risk Management Plan | Hazard Analysis Report&lt;br/&gt;Software Architecture Description | V&amp;amp;V Plan&lt;br/&gt;Threat Model | Cybersecurity Assessment | RMF&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1310" y="454" width="270" height="114" as="geometry" /></mxCell>
        <mxCell id="vd-note" value="&lt;b&gt;ISO 42010-style separation&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Concern -&gt; Viewpoint -&gt; View -&gt; Model content. A reviewer can ask for a risk table, a logical architecture diagram, or an RMF section and still receive a projection of the same versioned graph.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6faf3;strokeColor=#0d8b6f;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="210" y="730" width="1220" height="76" as="geometry" /></mxCell>
        <mxCell id="vd-e1" value="declares intent" style="endArrow=block;html=1;strokeColor=#666666;" edge="1" source="vd-vp" target="vd-query" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="vd-e2" value="binds content" style="endArrow=block;html=1;strokeColor=#666666;" edge="1" source="vd-query" target="vd-view" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="vd-e3" value="renders" style="endArrow=block;html=1;strokeColor=#666666;" edge="1" source="vd-view" target="vd-out" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="methodology-workflow" name="15-methodology-workflow">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="mw-title" value="&lt;b&gt;15. Methodology: Tailor the Ontology Without Forking It&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px;color:#4d4d4d&quot;&gt;Methodology selects scope, guides sequence, changes rigor, binds documents, and attaches quality gates to a project.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=20;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1480" height="54" as="geometry" /></mxCell>
        <mxCell id="mw-def" value="&lt;b&gt;MethodologyDefinition&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;version | domain | description&lt;br/&gt;baseMethodName&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1"><mxGeometry x="80" y="146" width="260" height="84" as="geometry" /></mxCell>
        <mxCell id="mw-res" value="&lt;b&gt;ResolvedMethodology&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;version | rigor&lt;br/&gt;resolutionSummary&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1"><mxGeometry x="430" y="146" width="260" height="84" as="geometry" /></mxCell>
        <mxCell id="mw-scope" value="&lt;b&gt;Scope selection&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;architecture layers&lt;br/&gt;standards&lt;br/&gt;artifact kinds&lt;br/&gt;viewpoint types&lt;br/&gt;excluded kinds&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef5ff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="780" y="126" width="220" height="124" as="geometry" /></mxCell>
        <mxCell id="mw-bind" value="&lt;b&gt;ProjectMethodBinding&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;projectName&lt;br/&gt;MethodologyBindingLink attaches&lt;br/&gt;resolved method to model element&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf6e8;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1090" y="146" width="300" height="84" as="geometry" /></mxCell>
        <mxCell id="mw-step1" value="&lt;b&gt;1. Capture Requirements&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Entry: intended use and actors understood&lt;br/&gt;Exit: initial requirement set exists&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1"><mxGeometry x="90" y="390" width="300" height="86" as="geometry" /></mxCell>
        <mxCell id="mw-step2" value="&lt;b&gt;2. Define Architecture&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Entry: initial requirements exist&lt;br/&gt;Exit: core architecture and interfaces exist&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef5ff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="450" y="390" width="300" height="86" as="geometry" /></mxCell>
        <mxCell id="mw-step3" value="&lt;b&gt;3. Perform Risk Analysis&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Entry: requirements and key behavior exist&lt;br/&gt;Exit: risk and control model exists&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8e8e8;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="810" y="390" width="300" height="86" as="geometry" /></mxCell>
        <mxCell id="mw-step4" value="&lt;b&gt;4. Plan Verification&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Entry: requirements and controls exist&lt;br/&gt;Exit: cases and evidence targets exist&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf6e8;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1170" y="390" width="300" height="86" as="geometry" /></mxCell>
        <mxCell id="mw-rules" value="&lt;b&gt;Rule strength and patterns&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ElementUsageRule | RelationUsageRule&lt;br/&gt;ModelingPattern&lt;br/&gt;required | recommended | forbidden&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="180" y="610" width="330" height="92" as="geometry" /></mxCell>
        <mxCell id="mw-gate" value="&lt;b&gt;QualityGate&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;gateStage | passCriteria&lt;br/&gt;Example: core traceability, risk, verification,&lt;br/&gt;and RMF view support are present&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf6e8;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="650" y="610" width="330" height="92" as="geometry" /></mxCell>
        <mxCell id="mw-dhf" value="&lt;b&gt;DHF document bindings&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Risk Management Plan | Hazard Analysis Report&lt;br/&gt;Software Architecture Description | Threat Model&lt;br/&gt;V&amp;amp;V Plan | lifecycle stage | required flag&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1120" y="610" width="350" height="92" as="geometry" /></mxCell>
        <mxCell id="mw-note" value="&lt;b&gt;Default versus GPCA&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;The comprehensive methodology can include all supported layers and standards. A GPCA-specific methodology can narrow the visible layers, standards, documents, viewpoints, and rule strengths while still consuming the same ontology release.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6faf3;strokeColor=#0d8b6f;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="180" y="820" width="1280" height="76" as="geometry" /></mxCell>
        <mxCell id="mw-e1" value="resolve" style="endArrow=block;html=1;strokeColor=#666666;" edge="1" source="mw-def" target="mw-res" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="mw-e2" value="select" style="endArrow=block;html=1;strokeColor=#666666;" edge="1" source="mw-res" target="mw-scope" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="mw-e3" value="bind" style="endArrow=block;html=1;strokeColor=#666666;" edge="1" source="mw-scope" target="mw-bind" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="mw-e4" value="" style="endArrow=block;html=1;strokeColor=#666666;" edge="1" source="mw-step1" target="mw-step2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="mw-e5" value="" style="endArrow=block;html=1;strokeColor=#666666;" edge="1" source="mw-step2" target="mw-step3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="mw-e6" value="" style="endArrow=block;html=1;strokeColor=#666666;" edge="1" source="mw-step3" target="mw-step4" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="gpca-risk-thread" name="16-gpca-worked-thread">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t2" value="&lt;b&gt;16. GPCA Pump Example: Follow One Safety Argument End-to-End&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:12px;color:#4d4d4d&quot;&gt;Concrete instances from memo-tools/memo/examples/gpca-pump show how the ontology turns scattered artifacts into an auditable graph.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=20;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1480" height="54" as="geometry" /></mxCell>
        <mxCell id="note2" value="&lt;b&gt;Scenario&lt;/b&gt;&lt;br/&gt;A patient requests another bolus during lockout. The architecture must prevent excess infusion, pause on critical alarms, and leave evidence that the controls were verified." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="40" y="84" width="1480" height="58" as="geometry" /></mxCell>

        <mxCell id="r1" value="&lt;b&gt;1. Clinical need&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;NEED-001&lt;br/&gt;SafePatientControlledTherapy&lt;br/&gt;Support safe patient-controlled analgesic infusion.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1"><mxGeometry x="60" y="190" width="250" height="116" as="geometry" /></mxCell>
        <mxCell id="r2" value="&lt;b&gt;2. Hazard chain&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;HZ-001 Overdose&lt;br/&gt;-&gt; SEQ-001 frequent bolus&lt;br/&gt;-&gt; HS-001 excess infusion exposure&lt;br/&gt;-&gt; HM-001 respiratory depression&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8e8e8;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="360" y="190" width="274" height="116" as="geometry" /></mxCell>
        <mxCell id="r3" value="&lt;b&gt;3. Risk before control&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;RISK-B-001&lt;br/&gt;Occasional x Catastrophic&lt;br/&gt;High - Unacceptable&lt;br/&gt;Assessed against RMX-001&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8e8e8;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="684" y="190" width="250" height="116" as="geometry" /></mxCell>
        <mxCell id="r4" value="&lt;b&gt;4. Risk controls&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;RC-001 LockoutAndMaxBolusEnforcement&lt;br/&gt;REQ-025 IgnoreFrequentBolusRequest&lt;br/&gt;REQ-019 AlarmStopsInfusion&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1"><mxGeometry x="984" y="190" width="290" height="116" as="geometry" /></mxCell>
        <mxCell id="r5" value="&lt;b&gt;5. Residual risk&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;RISK-A-001&lt;br/&gt;Remote x Catastrophic&lt;br/&gt;Acceptable with review&lt;br/&gt;RREV-001 residual evaluation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf6e8;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1324" y="190" width="250" height="116" as="geometry" /></mxCell>

        <mxCell id="a1" value="&lt;b&gt;Implementation allocation&lt;/b&gt;" style="swimlane;fontStyle=1;align=left;startSize=34;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1"><mxGeometry x="60" y="378" width="730" height="220" as="geometry" /></mxCell>
        <mxCell id="a1x" value="&lt;b&gt;SW-005 Infusion_Manager&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Class C software component&lt;br/&gt;Handles drug infusion commands and therapy parameters.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="a1"><mxGeometry x="28" y="62" width="310" height="70" as="geometry" /></mxCell>
        <mxCell id="a1y" value="&lt;b&gt;SW-003 Alarm&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Class C software component&lt;br/&gt;Monitors and notifies exceptional conditions.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="a1"><mxGeometry x="386" y="62" width="310" height="70" as="geometry" /></mxCell>
        <mxCell id="a1z" value="&lt;b&gt;ExecutionOrderLink&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Alarm precedes Infusion_Manager in the same execution step so infusion stops immediately.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="a1"><mxGeometry x="166" y="154" width="390" height="48" as="geometry" /></mxCell>

        <mxCell id="a2" value="&lt;b&gt;Verification and evidence&lt;/b&gt;" style="swimlane;fontStyle=1;align=left;startSize=34;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="840" y="378" width="734" height="220" as="geometry" /></mxCell>
        <mxCell id="a2x" value="&lt;b&gt;VER-002 VerifyBolusLockout&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Test: no bolus starts while lockout or max-bolus constraints are active.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="a2"><mxGeometry x="28" y="62" width="320" height="70" as="geometry" /></mxCell>
        <mxCell id="a2y" value="&lt;b&gt;EVD-001 BolusLockoutEvidence&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Evidence record produced by the verification case.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="a2"><mxGeometry x="386" y="62" width="320" height="70" as="geometry" /></mxCell>
        <mxCell id="a2z" value="&lt;b&gt;DocumentInclusionLink&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Evidence is included in the RMF view for regulated review.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="a2"><mxGeometry x="166" y="154" width="390" height="48" as="geometry" /></mxCell>

        <mxCell id="links" value="&lt;b&gt;The graph carries meaning through explicit link types&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;RequirementSourceLink: risk -&gt; requirement | RequirementSatisfactionLink: requirement -&gt; component | HazardMitigationLink: control -&gt; hazard | VerificationLink: target -&gt; case | EvidenceProductionLink: case -&gt; evidence | DocumentInclusionLink: evidence -&gt; RMF view&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="60" y="654" width="1514" height="74" as="geometry" /></mxCell>
        <mxCell id="rules" value="&lt;b&gt;Rules turn the graph into an engineering control system&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;The ontology checks closure: a hazard has mitigation, a risk control has verification, Class C software is verified, verification cases have methods and targets, and verification produces evidence. Coverage rules also report whether selected standards have the expected kinds.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="60" y="760" width="1514" height="74" as="geometry" /></mxCell>
        <mxCell id="rmf" value="&lt;b&gt;Review outcome: Risk Management File&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;The RMF is not a disconnected document. It is a controlled view over linked hazards, controls, residual-risk decisions, verification cases, and evidence.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf6e8;strokeColor=#82b366;fontSize=13;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="350" y="892" width="930" height="74" as="geometry" /></mxCell>

        <mxCell id="e12" value="drives analysis" style="endArrow=block;endFill=1;html=1;strokeColor=#666666;fontSize=10;" edge="1" source="r1" target="r2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e23" value="characterizes" style="endArrow=block;endFill=1;html=1;strokeColor=#666666;fontSize=10;" edge="1" source="r2" target="r3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e34" value="requires mitigation" style="endArrow=block;endFill=1;html=1;strokeColor=#666666;fontSize=10;" edge="1" source="r3" target="r4" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e45" value="results in" style="endArrow=block;endFill=1;html=1;strokeColor=#666666;fontSize=10;" edge="1" source="r4" target="r5" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4a" value="satisfied by" style="endArrow=block;endFill=1;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;fontSize=10;" edge="1" source="r4" target="a1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea2" value="verified by" style="endArrow=block;endFill=1;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontSize=10;" edge="1" source="a1" target="a2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ermf" value="compiled into controlled view" style="endArrow=block;endFill=1;html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontSize=10;" edge="1" source="a2" target="rmf" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
